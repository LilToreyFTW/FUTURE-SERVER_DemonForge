# DemonForge Engine Environment Variables

# API Key for authentication (change this in production!)
DEMONFORGE_API_KEY=demo-api-key-change-me

# Public API URL for frontend
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Public API Key for frontend (same as DEMONFORGE_API_KEY for now)
NEXT_PUBLIC_API_KEY=demo-api-key-change-me
